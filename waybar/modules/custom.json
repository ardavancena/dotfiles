{
    "custom/notification_center": {
        "format": "",
        "tooltip": false,
        "on-click": "swaync-client -t",
        "on-click-right": "swaync-client -d",
        "interval": 1,
        "return-type": "json"
    },

    "custom/settings": {
        "format": "⚙",
        "tooltip": false,
        "on-click": "hyprmod"
    },

    "custom/launcher": {
        "format": "󰣇",
        "tooltip": false,
        "on-click": "rofi --show drun"
    },

    "custom/clipboard": {
        "format": "",
        "tooltip": false,
        "on-click": "copyq toggle"
    },

    "custom/language": {
        "exec": "~/.config/waybar/scripts/keyboard-layout.sh",
        "interval": 1,
        "format": "{}",
        "tooltip": false
    },

    "custom/endeavouros": {
        "format": ""
    },

    "custom/app-launcher": {
        "format": "󱪳",
        "on-click": "rofi -config ~/.config/rofi/app-launcher.rasi -show drun"
    }

}
