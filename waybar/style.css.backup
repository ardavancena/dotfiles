* {
    font-family: "Inter", "JetBrainsMono Nerd Font", sans-serif;
    font-size: 20px;
    color: #ffffff;
    padding: 0px;
    margin: 0px;
    border-radius: 5px;
    min-width: 30px;
}

/***************************************/
/*       Default Module Configs        */
/***************************************/

#clock,
#battery,
#cpu,
#memory,
#network,
#bluetooth,
#workspaces,
#custom-language,
#custom-settings,
#custom-notification_center,
#custom-endeavouros,
#pulseaudio {
/*    background: #3e3f5e; */
/*    background: #201F25; */
    background: #27252A;

    border-radius: 120px;
    color: #ffffff;
/*    padding: 10px 16px; */
    margin: 4px 4px;
}

/*--------------------------*/
/*      CUSTOM MODULES      */
/*--------------------------*/

#custom-endeavouros {
    font-size: 25px;
    background: transparent;
    margin: 5px;
    margin-right: 0px;
    padding: 0px;
    min-width: 50px;
    border-radius: 15px;
}

#custom-language {
    padding: 0px;
    min-width: 50px;
    border-radius: 21px;
    margin-left: 0px;
    margin-right: 0px;
/*    min-width: 10px; */
/*    padding-left: 10px;
    padding-right: 10px;
    margin: 3px; */
}

#custom-settings {
    min-width: 50px;
    border-radius: 17px;
}

#custom-notification_center {
    margin: 5px;
    padding: 0px;
    margin-right: 5px;
    min-width: 50px;
    border-radius: 20px;
    margin-left: 0px;
}

/*                              */
/*        Module Configs        */
/*                              */

#clock {
    margin: 5px;
    margin-left: 0px;
    margin-right: 0px;
    min-width: 90px;

}

#workspaces {
/*    background: #3e3f5e; */
    border-radius: 200px;
    padding: 5px;
}

#workspaces button {
/*    min-width: 28px; */
/*    min-height: 28px; */
/*    background: #3e3f5e; */
    padding: 5px;
    border-radius: 200px;
    color: #a6a9c5;
    transition: all 0.2s ease;
}

#workspaces button.active {
    background: #484459;
    color: #ffffff;
}

#workspaces button:hover {
    background: #484459;
    color: #ffffff;
}

#workspaces button.urgent {
/*    background: #ffa3b3; */
    background: #5b5e85;
    color: #ffffff;
}

#workspaces button label {
    font-weight: 500;
}

/* Remove old conflicting styles */
#workspaces button.focused {
    background-color: #7c7fae;
    box-shadow: none;
}

#network {
    padding: 0px;
/*    min-width: 50px; */
}

#network.disconnected {
    background: #990000;
    color: #AA0000;
}

/* Make the group visible instead */
#system {
    background: #27252A;
    border-radius: 120px;
/*    margin: 4px 4px; */
    margin: 5px;
    margin-left: 0px;
    margin-right: 0px;
}

/* Add separators between modules */
#system > *:not(:last-child) {
    border-right: 0px solid rgba(255, 255, 255, 0.2);
}

/* First and last child rounded corners */
#system > *:first-child {
    border-radius: 120px 0 0 120px;
    padding-left: 16px ;
}

#system > *:last-child {
    border-radius: 0 120px 120px 0;
    padding-right: 16px ;
}

window#waybar {
/*    background-color: rgba(20, 19, 25, 1.0); */
/*    background: transparent; */
/*    background: #141318; */
    background: #131216;
    color: #ffffff;
    transition-property: background-color;
    transition-duration: .5s;
}

window#waybar.hidden {
    opacity: 0.2;
}

window#waybar.termite {
    background-color: #3F3F3F;
}

window#waybar.chromium {
    background-color: #000000;
    border: none;
}

button {
    box-shadow: inset 0 -3px transparent;
    border: none;
}

button:hover {
    background: inherit;
    box-shadow: inset 0 -3px #ffffff;
}

#mode {
    border-bottom: 3px solid #ffffff;
}

.modules-left > widget:first-child > #workspaces {
    margin-left: 0;
}

.modules-right > widget:last-child > #workspaces {
    margin-right: 0;
}

#battery.charging, #battery.plugged {
    color: #ffffff;
    background-color: #26A65B;
}

@keyframes blink {
    to {
        background-color: #ffffff;
        color: #000000;
    }
}

#battery.critical:not(.charging) {
    background-color: #f53c3c;
    color: #ffffff;
    animation-name: blink;
    animation-duration: 0.5s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-direction: alternate;
}

label:focus {
    background-color: #000000;
}

#cpu {
    background-color: #2ecc71;
    color: #000000;
}

#battery {
    min-width: 50px;
    padding-left: 0px;
    padding-right: 0px;
}
#language {
    background: #00b093;
    color: #740864;
    padding: 0 5px;
    margin: 0 5px;
    min-width: 16px;
}

#keyboard-state {
    background: #97e1ad;
    color: #000000;
    padding: 0 0px;
    margin: 0 5px;
    min-width: 16px;
}

#keyboard-state > label {
    padding: 0 5px;
}

#keyboard-state > label.locked {
    background: rgba(0, 0, 0, 0.2);
}

#scratchpad {
    background: rgba(0, 0, 0, 0.2);
}

#scratchpad.empty {
    background-color: transparent;
}

